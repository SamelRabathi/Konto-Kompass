APP_ENV=dev
# Kein $ im Passwort, oder als $$ escapen (z.B. geheim$$wort → geheim$wort)
POSTGRES_PASSWORD=change-me-use-only-letters-and-numbers
APP_SECRET=change-me-super-long-random-string-at-least-32-chars
JWT_EXPIRE_MINUTES=10080

WEALTHAPI_KEY=your-wealthapi-key
WEALTHAPI_BASE_URL=https://api.wealthapi.eu

GOCARDLESS_SECRET_ID=your-gocardless-secret-id
GOCARDLESS_SECRET_KEY=your-gocardless-secret-key
GOCARDLESS_BASE_URL=https://bankaccountdata.gocardless.com/api/v2
